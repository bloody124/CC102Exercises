#include <iostream>
#include <fstream>
#include <vector>
#include <algorithm>
using namespace std;

int main() {
    ofstream outFile("original.txt");
    if (!outFile.is_open()) {
        return 1;
    }

    outFile << "One\n";
    outFile << "Two\n";
    outFile << "Three\n";
    outFile << "Four\n";
    outFile << "Five\n";
    outFile << "Six\n";
    outFile.close();

    ifstream inFile("original.txt");
    if (!inFile.is_open()) {
        return 1;
    }

    vector<string> words;
    string line;
    while (getline(inFile, line)) {
        words.push_back(line);
    }
    inFile.close();

    sort(words.begin(), words.end());

    ofstream sortedFile("sorted.txt");
    if (!sortedFile.is_open()) {
        return 1;
    }

    for (const string& word : words) {
        sortedFile << word << endl;
    }

    sortedFile.close();

    return 0;
}
